            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 - booking not COMPLETED', () => pm.response.to.have.status(400));",
                  "pm.test('Error message mentions booking completion', () => {",
                  "  const body = pm.response.text().toLowerCase();",
                  "  pm.expect(body).to.satisfy(b => b.includes('complet') || b.includes('complete'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}", "type": "text" }],
            "body": {
              "mode": "formdata",
              "formdata": [
